# Copy to .env and fill in. Leaving BOTH credentials of a gateway empty disables
# its auth (open/unauthenticated access) — set them for any real deployment.

# Published image to pull. Pin a version tag for reproducible deploys,
# e.g. solkin/birak:1.2.3 (the ":latest" tag moves on every release).
BIRAK_IMAGE=solkin/birak:latest

# Node identity (unique per node in a cluster).
BIRAK_NODE_ID=node-1

# S3 gateway credentials (AWS Signature V4).
S3_ACCESS_KEY=changeme-access-key
S3_SECRET_KEY=changeme-secret-key

# HTTP UI credentials (basic auth).
HTTP_USERNAME=admin
HTTP_PASSWORD=changeme-password
